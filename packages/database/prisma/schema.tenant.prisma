generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  phoneCode String?
  currency  String?
  flag      String?
  createdAt DateTime @default(now())

  cities City[]
}

model City {
  id          String   @id @default(cuid())
  name        String
  code        String?
  countryCode String
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  country     Country      @relation(fields: [countryCode], references: [code])
  tripsFrom   Trip[]       @relation("TripFrom")
  tripsTo     Trip[]       @relation("TripTo")
  stations    Station[]
  locations   AgencyLocation[]
}

model AgencyLocation {
  id        String   @id @default(cuid())
  name      String
  address   String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  cityId String?
  city   City?   @relation(fields: [cityId], references: [id])

  locationId String?
  location   AgencyLocation? @relation("LocationBranches", fields: [locationId], references: [id])
  branches    AgencyLocation[] @relation("LocationBranches")

  roles  AgencyRole[] @relation("AgencyRoleLocation")
  buses  Bus[] @relation("BusLocation")
  members   AgencyMember[]
  trips     Trip[] @relation("TripLocation")
  bookings  Booking[]
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  status      String   @default("PENDING")
  countryCode String   @default("CM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("AgencyOwner", fields: [ownerId], references: [id])

  tenantId String? @unique
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  locations       AgencyLocation[]
  members         AgencyMember[]
  trips           Trip[]
  bookings        Booking[]
  transactions    Transaction[]
  reports         Report[]
  feedbacks       Feedback[]
  subscriptions   AgencySubscription[]
  stations        Station[]
  buses           Bus[]

  @@index([ownerId])
  @@index([status])
  @@index([slug])
}

model AgencyRole {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  locationId String?
  location   AgencyLocation? @relation("AgencyRoleLocation", fields: [locationId], references: [id])

  members AgencyMember[]
}

model AgencyMember {
  id        String   @id @default(cuid())
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  locationId String?
  location   AgencyLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  roleId String
  role   AgencyRole @relation(fields: [roleId], references: [id])

  tripsAsDriver Trip[] @relation("TripDriver")
  feedbacksAsDriver Feedback[] @relation("FeedbackDriver")

  @@index([userId])
  @@index([agencyId])
  @@index([roleId])
}

model Bus {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  title     String
  status    String   @default("ACTIVE")

  maxPlaces    Int
  licensePlate String @unique

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  locationId String?
  location   AgencyLocation? @relation("BusLocation", fields: [locationId], references: [id], onDelete: SetNull)

  trips Trip[]
  seats Seat[]

  seatReservationType String @default("UNNUMBERED")

  @@index([agencyId])
  @@index([locationId])
}

model Trip {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status    String   @default("SCHEDULED")
  price     Float

  departureDate DateTime
  departureTime DateTime?
  arrivalTime   DateTime?

  availableSeats Int @default(0)

  busId String?
  bus   Bus?   @relation(fields: [busId], references: [id], onDelete: SetNull)

  driverId String?
  driver   AgencyMember? @relation("TripDriver", fields: [driverId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  departureStationId String?
  departureStation  Station?   @relation("TripDepartureStation", fields: [departureStationId], references: [id])

  arrivalStationId String?
  arrivalStation   Station?   @relation("TripArrivalStation", fields: [arrivalStationId], references: [id])

  departureCityId String?
  departureCity   City?   @relation("TripFrom", fields: [departureCityId], references: [id])

  arrivalCityId String?
  arrivalCity   City?   @relation("TripTo", fields: [arrivalCityId], references: [id])

  locationId String?
  location   AgencyLocation? @relation("TripLocation", fields: [locationId], references: [id], onDelete: SetNull)

  bookings      Booking[]
  tickets       Ticket[]
  feedbacks     Feedback[]

  @@index([agencyId])
  @@index([departureDate])
  @@index([status])
  @@index([busId])
}

model Station {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  address   String?
  latitude  Float?
  longitude Float?

  cityId String?
  city   City?   @relation(fields: [cityId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  tripsDeparting Trip[] @relation("TripDepartureStation")
  tripsArriving  Trip[] @relation("TripArrivalStation")

  @@index([agencyId])
  @@index([cityId])
}

model Booking {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status          String   @default("PENDING")
  totalAmount     Float
  passengerName   String?
  passengerPhone  String?
  passengerEmail  String?
  paymentMethod   String?
  paymentStatus   String   @default("UNPAID")
  reference       String   @unique

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  locationId String?
  location   AgencyLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  tickets       Ticket[]
  transaction   Transaction?
  feedbacks     Feedback[]

  @@index([tripId])
  @@index([userId])
  @@index([agencyId])
  @@index([reference])
}

model Ticket {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  seatNumber  String
  status      String   @default("VALID")

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id])

  @@index([bookingId])
  @@index([tripId])
}

model Seat {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  rowNumber   Int
  columnNumber Int
  seatNumber  String
  type        String   @default("STANDARD")

  busId String
  bus   Bus   @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId])
}

model Transaction {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String
  amount      Float
  currency    String   @default("XAF")
  status      String   @default("PENDING")
  reference   String
  description String?

  bookingId String? @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agencyId])
  @@index([status])
  @@index([reference])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  type      String
  title     String
  message   String
  status    String   @default("UNREAD")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Report {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String
  title       String
  description String?
  status      String   @default("PENDING")

  createdBy String

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([status])
}

model Feedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  rating    Int
  comment   String?
  type      String   @default("GENERAL")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tripId String?
  trip   Trip?   @relation(fields: [tripId], references: [id])

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  driverId String?
  driver   AgencyMember? @relation("FeedbackDriver", fields: [driverId], references: [id])

  @@index([userId])
  @@index([tripId])
  @@index([agencyId])
}

model AgencySubscription {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agencyId String @unique
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  status          String   @default("TRIAL")
  trialStartDate  DateTime @default(now())
  trialEndDate    DateTime

  invoices Invoice[]

  @@index([status])
  @@index([trialEndDate])
}

model Invoice {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  amount      Float
  currency    String   @default("XAF")
  status      String   @default("PENDING")
  issuedAt    DateTime @default(now())
  dueDate     DateTime
  paidAt      DateTime?
  description String?

  subscriptionId String
  subscription   AgencySubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
  @@index([status])
  @@index([dueDate])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role String @default("USER")

  profile     Profile?
  sessions    Session[]
  accounts    Account[]
  bookings    Booking[]
  transactions Transaction[]
  notifications Notification[]

  agenciesOwned    Agency[]        @relation("AgencyOwner")
  agencyMemberships AgencyMember[]

  feedbacks Feedback[]
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  phoneNumber  String?
  dateOfBirth  DateTime?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token         String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ipAddress     String?
  userAgent    String?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatorId String?
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  Int?
  refreshTokenExpiresAt Int?
  scope                 String?
  password              String?

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model TwoFactor {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  secret      String?
  backupCodes String?
}

model TwoFactor {
  id        String   @id @default(cuid())
  userId    String   @unique
  secret    String
  backupCodes String[]
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  databaseName String  @unique
  status      String   @default("PROVISIONING")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  provisionedAt DateTime?

  approvedBy  String?
  approvedAt DateTime?
  suspendedAt DateTime?
  suspendedReason String?

  agency Agency?

  @@index([status])
  @@index([slug])
}