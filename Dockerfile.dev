FROM node:20-alpine

# Install pnpm and system dependencies
RUN npm install -g pnpm@10.30.0 && \
    apk add --no-cache curl git

# Set working directory
WORKDIR /app

# Copy package manager configuration files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./

# Copy all package.json files to preserve workspace structure
COPY apps/*/package.json ./apps/
COPY packages/*/package.json ./packages/

# Copy all packages directory (needed for workspace resolution)
COPY packages ./packages

# Install dependencies (allow lockfile updates in development)
RUN pnpm install

# Copy all source code (excluding node_modules to avoid symlink issues)
COPY . .

# Ensure all workspace dependencies are properly linked and installed
RUN pnpm install --recursive

# Regenerate Prisma client with correct binary targets for Alpine Linux
RUN pnpm --filter @repo/database generate

# Copy entrypoint script
COPY ./scripts/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Expose ports for different services
# 3000: Admin (Next.js)
# 3001: Admin (Next.js dev server)
# 3003: Server (Hono API)
# 3005: Studio (Prisma Studio)
EXPOSE 3000 3001 3003 3005

# Use entrypoint script
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["pnpm", "turbo", "run", "dev", "--filter=!com.viago.client"]
