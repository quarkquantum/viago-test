{
  "name": "@repo/server",
  "type": "module",
  "exports": {
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "default": "./dist/rpc.js"
    }
  },
  "packageManager":"pnpm@10.12.4",
  "scripts": {
    "build": "tsdown",
    "dev": "pnpm with-env tsx watch --clear-screen=false ./src/index.ts",
    "start": "tsx ./dist/index.js",
    "clean": "git clean -xdf .cache .next .turbo node_modules dist",
    "check-types": "tsdown --check-types",
    "with-env": "dotenv -e ../../.env --",
    "seed": "pnpm with-env tsx ./src/database/seed/index.ts",
    "seed:dev": "pnpm with-env tsx ./src/database/seed/index.ts --environment=development",
    "seed:staging": "pnpm with-env tsx ./src/database/seed/index.ts --environment=production",
    "seed:prod": "pnpm with-env tsx ./src/database/seed/index.ts --environment=production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.994.0",
    "@hono/node-server": "^1.19.9",
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@intlify/hono": "^2.0.0",
    "@opentelemetry/instrumentation-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-node": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@repo/auth": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/logger": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/validators": "workspace:*",
    "@scalar/hono-api-reference": "^0.9.44",
    "@t3-oss/env-core": "^0.13.10",
    "bullmq": "5.69.3",
    "cloudflare": "^5.2.0",
    "destr": "^2.0.5",
    "dotenv-cli": "^11.0.0",
    "file-type": "^21.3.0",
    "firebase-admin": "^13.6.1",
    "fs-extra": "^11.3.3",
    "hono": "^4.12.0",
    "hono-openapi": "^1.2.0",
    "ioredis": "5.9.3",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6",
    "openapi-types": "^12.1.3",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "slugify": "^1.6.6",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@repo/tsconfig": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.3.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
