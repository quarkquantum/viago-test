{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/tsconfig/hono.json",
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/i18n/**/*.json",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
